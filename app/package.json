{
  "name": "@signet/cli",
  "version": "0.2.0",
  "type": "module",
  "description": "Signet — agent-native release network on Sui + Walrus: CLI, MCP server, and SDK",
  "bin": {
    "forge": "./bin/forge.mjs",
    "signet": "./bin/forge.mjs",
    "signet-mcp": "./bin/mcp.mjs"
  },
  "main": "./src/sdk.ts",
  "types": "./src/sdk.ts",
  "exports": {
    ".": "./src/sdk.ts",
    "./sdk": "./src/sdk.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "forge": "tsx src/cli/index.ts",
    "mcp": "tsx src/mcp/server.ts",
    "ci": "tsx src/ci/worker.ts",
    "agent:demo": "node --import tsx scripts/mcp-agent-demo.mjs",
    "seed": "node --import tsx scripts/seed-network.mjs",
    "doctor": "tsx src/cli/index.ts doctor",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "coverage": "node --import tsx --test --experimental-test-coverage test/*.test.ts",
    "e2e:onchain": "node --import tsx scripts/e2e-onchain.mjs",
    "prepublishOnly": "tsc --noEmit",
    "pack:dry": "npm pack --dry-run"
  },
  "files": [
    "bin",
    "src",
    "scripts",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "sui",
    "walrus",
    "ai-agents",
    "mcp",
    "provenance",
    "verifiable-memory",
    "reputation"
  ],
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/kravadk/signet.git", "directory": "app" },
  "homepage": "https://github.com/kravadk/signet#readme",
  "bugs": "https://github.com/kravadk/signet/issues",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mysten/sui": "^1.30.0",
    "commander": "^12.1.0",
    "tsx": "^4.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.7.0"
  }
}
