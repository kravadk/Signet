# Signet sponsor service — copy to .env (or set in your host's dashboard).

# REQUIRED: the sponsor wallet's private key (bech32 `suiprivkey1...`). This wallet
# PAYS GAS for users, so fund it and keep it low-balance / rotatable. Never commit it.
# Generate a fresh one:  sui client new-address ed25519   then  sui keytool export --key-identity <addr>
SPONSOR_PRIVATE_KEY=suiprivkey1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# REQUIRED: the Playground package id(s) the sponsor will pay for (comma-separated).
# testnet latest v9 (private apps): 0x1fac353343e74dbf2757d6ea475127fcafc6dadbcf3737b4116f365eb7fbb61e
# testnet v8 (paid-fork): 0xb2054d83ea80eac464e9601e0c9a5e7a06920e0161ca4f313ec03c4d3c62a760
# mainnet (paid-fork + private apps): 0x60e6933e4b92c4deb2f9afb37c143581d1bd589b2f2a32d76c9c2189a287b36a
ALLOWED_PACKAGES=0x1fac353343e74dbf2757d6ea475127fcafc6dadbcf3737b4116f365eb7fbb61e,0xb2054d83ea80eac464e9601e0c9a5e7a06920e0161ca4f313ec03c4d3c62a760

SUI_NETWORK=testnet
PORT=8788
# Lock to your deployed site origin in production; * only for local dev.
ALLOWED_ORIGIN=*
RATE_LIMIT_PER_MIN=15
WALLET_RATE_LIMIT_PER_MIN=20
IP_DAILY_LIMIT=250
WALLET_DAILY_LIMIT=100
DAILY_BUDGET_MIST=1000000000
FUNCTION_DAILY_LIMITS=publish_app=25,publish_app_v2=25,publish_remix_v3=25,update_app=50,*=500
# open | allowlist | stake. Applies only to publish/update/remix sponsorship.
SPONSOR_WRITE_MODE=open
ALLOWED_SENDERS=
STAKE_MIN_MIST=0
# Gas cap per sponsored tx (MIST). 20_000_000 = 0.02 SUI.
GAS_BUDGET=20000000
