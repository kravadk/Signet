# WalrusForge LLM proxy — copy to .env (or set in your host's dashboard).
# REQUIRED: your Anthropic key. Stays server-side; never shipped to the browser.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional tuning.
PORT=8787
# Lock CORS to your deployed site origin in production, e.g. https://walrusforge.wal.app
# Use * only for local dev.
ALLOWED_ORIGIN=*
RATE_LIMIT_PER_MIN=20
MAX_TOKENS=8000
