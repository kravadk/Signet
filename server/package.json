{
  "name": "signet-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Signet indexer + REST API (Sui events -> SQLite -> HTTP)",
  "scripts": {
    "dev": "node --experimental-sqlite --import tsx watch src/index.ts",
    "start": "node --experimental-sqlite --import tsx src/index.ts",
    "reindex": "node --experimental-sqlite scripts/reindex.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mysten/sui": "^1.30.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
