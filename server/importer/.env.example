# Signet GitHub importer — keyless, testnet-oriented.
PORT=8795
# Walrus network for the snapshot upload (testnet has a free publisher).
FORGE_NETWORK=testnet
# CORS: '*' for local dev; set to your web origin in production.
ALLOWED_ORIGIN=*
# Reject repos with more than this many files.
MAX_FILES=2000
# Walrus storage epochs for the uploaded blobs.
EPOCHS=30
# git clone timeout (ms).
CLONE_TIMEOUT_MS=60000
