# Signet zkLogin salt service — copy to .env (or set in your host dashboard).

# REQUIRED: long random secret. salt = HMAC(SALT_SECRET, iss|aud|sub).
# Keep it SECRET and STABLE — rotating it changes every user's Sui address.
SALT_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Your Google OAuth client id. If set, the JWT's `aud` must match it.
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com

PORT=8789
# JWKS endpoint for verifying the id_token (default: Google).
JWKS_URL=https://www.googleapis.com/oauth2/v3/certs
ALLOWED_ISS=https://accounts.google.com,accounts.google.com
# Lock to your deployed site origin in production; * only for local dev.
ALLOWED_ORIGIN=*
