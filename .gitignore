# Dependencies
node_modules/
**/node_modules/

# Build output
**/build/
**/.next/
**/dist/
**/out/
*.tsbuildinfo

# Move build
move/walrusforge/build/

# Indexer database (rebuildable from chain)
server/*.db
server/*.db-*

# Local CLI state + demo scratch
**/.forge/
demo/sample-repo/

# Secrets — never commit keys
*.key
.env
.env.*
*.agent.env
!.env.example

# Transient CLI / deploy output artifacts (not source)
move/walrusforge/*-out.json
move/walrusforge/*-err.txt
move/walrusforge/mn-*.json
move/walrusforge/publish*.json
move/walrusforge/forkreg*.json
move/walrusforge/privreg*.json
move/walrusforge/upgrade-*
.claude/scheduled_tasks.lock

# Scratch / backups (not part of the shipped project)
web-next-backup/
web-annotate/

# OS / editor
.DS_Store
*.log
