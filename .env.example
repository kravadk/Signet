# Signet — copy to .env (gitignored) for the local/docker stack.
# Locally, `scripts/gen-web-config.mjs` (run by `npm run dev:all`) and the web
# Docker entrypoint read the WF_* values; the services read the rest.

# --- Network ---
SUI_NETWORK=testnet

# --- Sponsor service (gas-free actions) ---
# A funded wallet key (testnet: faucet it; mainnet: real SUI — rotate the compromised 0x9de8 first).
SPONSOR_PRIVATE_KEY=suiprivkey1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Playground package id(s) the sponsor will pay for, comma-separated.
# testnet latest v9 (private apps): 0x1fac...
# include older event/entry packages only if you intentionally sponsor old write paths.
ALLOWED_PACKAGES=0x1fac353343e74dbf2757d6ea475127fcafc6dadbcf3737b4116f365eb7fbb61e,0xb2054d83ea80eac464e9601e0c9a5e7a06920e0161ca4f313ec03c4d3c62a760
GAS_BUDGET=20000000
RATE_LIMIT_PER_MIN=15
WALLET_RATE_LIMIT_PER_MIN=20
IP_DAILY_LIMIT=250
WALLET_DAILY_LIMIT=100
DAILY_BUDGET_MIST=1000000000
# Per-function daily sponsorship caps. "*" is the default for other allowlisted calls.
FUNCTION_DAILY_LIMITS=publish_app=25,publish_app_v2=25,publish_remix_v3=25,update_app=50,*=500
# open | allowlist | stake. Applies only to publish/update/remix sponsorship.
SPONSOR_WRITE_MODE=open
ALLOWED_SENDERS=
STAKE_MIN_MIST=0

# --- Gallery seeder (npm run seed:gallery) ---
FORGE_SEED_KEY=suiprivkey1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- LLM proxy (build without BYOK) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Salt service (zkLogin) ---
SALT_SECRET=replace-with-a-long-random-string-at-least-32-chars
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com

# --- CORS: set to your web origin in production, or * for local ---
WEB_ORIGIN=*
PORTAL_ORIGIN=http://localhost:8790

# --- Browser-reachable service URLs injected into web/config.js ---
WF_SPONSOR_URL=http://localhost:8788/sponsor
WF_PORTAL_URL=http://localhost:8790
WF_LLM_PROXY_URL=http://localhost:8787/llm
WF_ZK_SALT_URL=http://localhost:8789/salt
WF_ZK_PROVER_URL=
WF_ZK_GOOGLE_CLIENT_ID=
